# Server
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fashion_cotz

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Fashion.co.tz <noreply@fashion.co.tz>

# Snippe.sh Payments
SNIPPE_API_KEY=your_snippe_api_key
SNIPPE_WEBHOOK_SECRET=your_snippe_webhook_secret
SNIPPE_API_URL=https://api.snippe.sh/v1
BACKEND_URL=https://api.fashion.co.tz

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Subscription
SUBSCRIPTION_AMOUNT=5000
SUBSCRIPTION_DURATION_DAYS=7
